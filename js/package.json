{
  "scripts": {
    "sass:build": "sass sass/style.sass css/style.css",
    "sass:clean": "perl -pi -e 's/[ \\t]+$//' sass/*.sass sass/blocks/*.sass",
    "sass:fix": "sass-lint-auto-fix \"sass/**/*.sass\" -c .sass-lint-auto-fix.yml --config-sass-lint .sass-lint.yml && npm run sass:clean",
    "sass:lint": "sass-lint -c .sass-lint.yml -v -q"
  },
  "devDependencies": {
    "sass": "^1.89.2",
    "sass-lint": "^1.13.1",
    "sass-lint-auto-fix": "^0.21.2"
  }
}
